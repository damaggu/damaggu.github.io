  pages={4929},
  year={2020},
  publisher={Nature Publishing Group UK London},
  preview={fus.png},
  html={https://www.nature.com/articles/s41467-020-18059-7},
  abstract={Non-invasive, molecularly-specific, focal modulation of brain circuits with low off-target effects can lead to breakthroughs in treatments of brain disorders. We systemically inject engineered ultrasound-controllable drug carriers and apply a novel two-component focused ultrasound sequence at desired targets inside the brain to aggregate and uncage drug carriers with millimeter-precision, achieving high target specificity without compromising the blood-brain barrier.},
}

