@inproceedings{carion2025sam,
    title={SAM 3: Segment Anything with Concepts},
    author={Carion, Nicolas and Gustafson, Laura and Hu, Yuan-Ting and Debnath, Shoubhik and Hu, Ronghang and Suris, Didac and Ryali, Chaitanya and Alwala, Kalyan Vasudev and Khedr, Haitham and Huang, Andrew and Lei, Jie and Ma, Tengyu and Guo, Baishan and Kalla, Arpit and Marks, Markus and Greer, Joseph and Wang, Meng and Sun, Peize and Rädle, Roman and Afouras, Triantafyllos and Mavroudi, Effrosyni and Xu, Katherine and Wu, Tsung-Han and Zhou, Yu and Momeni, Liliane and Hazra, Rishi and Ding, Shuangrui and Vaze, Sagar and Porcher, Francois and Li, Feng and Li, Siyuan and Kamath, Aishwarya and Cheng, Ho Kei and Dollár, Piotr and Ravi, Nikhila and Saenko, Kate and Zhang, Pengchuan and Feichtenhofer, Christoph},
    booktitle={International Conference on Learning Representations (ICLR)},
    abbr={ICLR},
    year={2026},
    code={https://github.com/facebookresearch/sam3},
    website={https://ai.meta.com/blog/segment-anything-model-3/},
    html={https://ai.meta.com/research/publications/sam-3-segment-anything-with-concepts/},
    selected={true},
    preview={sam3.gif},
    arxiv={2511.16719},
    abstract={We present Segment Anything Model (SAM) 3, a unified model that detects, segments, and tracks objects in images and videos based on concept prompts, which we define as either short noun phrases (e.g., "yellow school bus"), image exemplars, or a combination of both. Promptable Concept Segmentation (PCS) takes such prompts and returns segmentation masks and unique identities for all matching object instances. To advance PCS, we build a scalable data engine that produces a high-quality dataset with 4M unique concept labels, including hard negatives, across images and videos. Our model consists of an image-level detector and a memory-based video tracker that share a single backbone. Recognition and localization are decoupled with a presence head, which boosts detection accuracy. SAM 3 doubles the accuracy of existing systems in both image and video PCS, and improves previous SAM capabilities on visual segmentation tasks.},
}

@article{israel2023foundation,
  title={CellSAM: a foundation model for cell segmentation},
  author={Marks*, Markus and Israel*, Uriah and Dilip, Rohit and Li, Qilin and Schwartz, Morgan and Pradhan, Elora and Pao, Edward and Li, Shenyi and Pearson-Goulart, Alexander and Perona, Pietro and Gkioxari, Georgia and Barnowski, Ross and Yue, Yisong and Van Valen, David Ashley},
  journal={Nature Methods},
  abbr={Nature Methods},
  year={2025},
  preview={cellsam.png},
  selected={true},
  html={https://www.nature.com/articles/s41592-025-02879-w},
  website={https://cellsam.deepcell.org/},
  code={https://github.com/vanvalenlab/cellSAM},
  abstract={Cells are a fundamental unit of biological organization, and identifying them in imaging data is a critical task for various cellular imaging experiments. We present CellSAM, a universal model for cell segmentation that generalizes across diverse cellular imaging data. CellSAM builds on top of the Segment Anything Model by developing a prompt engineering approach for mask generation. We show that this approach allows a single model to achieve human-level performance for segmenting images of mammalian cells, yeast and bacteria collected across various imaging modalities.},
}

@article{guimaraes2025diffusionbasedactionrecognitiongeneralizes,
      title={Diffusion-Based Action Recognition Generalizes to Untrained Domains},
      author={Rogerio Guimaraes and Frank Xiao and Pietro Perona and Markus Marks},
      year={2026},
      month={March},
      arxiv={2509.08908},
      abstract={Humans can recognize the same actions despite large context and viewpoint variations. Current deep learning models struggle with such generalization. We propose using features generated by a Vision Diffusion Model, aggregated via a transformer, to achieve human-like action recognition across these challenging conditions. We find that generalization is enhanced by the use of a model conditioned on earlier timesteps of the diffusion process. Our model sets a new state-of-the-art across all three generalization benchmarks, bringing machine action recognition closer to human-like robustness.},
      archivePrefix={arXiv},
      primaryClass={cs.CV},
      code={https://github.com/frankyaoxiao/ActionDiff},
      website={https://www.vision.caltech.edu/actiondiff/},
      preview={actiondiff.png},
      journal={Proceedings of the IEEE/CVF Winter Conference on Applications of Computer Vision},
      abbr={WACV},
}


@article{yanik2025magnetic,
  title={Magnetic Resonance Identification Tags for Ultra-flexible Electrodes},
  author={Ozil, Eminhan and Gombkoto, Peter and Apostolelli, Athina and Yasar, Tansel and Vavladeli, Angeliki and Marks, Markus and von der Behrens, Wolfger and Yanik, Mehmet},
  year={2025},
  preview={mritag.png},
  html={https://www.researchsquare.com/article/rs-6406139/v1},
  abstract={We present magnetic resonance identification tags for ultra-flexible electrodes, enabling precise localization of implanted neural probes in MRI. This approach addresses a key challenge in combining electrophysiology with whole-brain imaging in preclinical neuroscience research.},
}

@article{stathatos2025saved,
    title={SAVeD: Learning to Denoise Low-SNR Video for Improved Downstream Performance},
    author={Stathatos, Suzanne and Hobley, Michael and Perona*, Pietro and Marks*, Markus},
    journal={Proceedings of the IEEE/CVF Winter Conference on Applications of Computer Vision},
    abbr={WACV},
    arxiv={2504.00161},
    abstract={Low signal-to-noise ratio videos pose significant challenges for computer vision models, particularly when paired clean imagery is unavailable. We present SAVeD, a novel self-supervised method that denoises low-SNR sensor videos using only raw noisy data. By leveraging distinctions between foreground and background motion, SAVeD enhances foreground object visibility and reduces background and camera noise without requiring clean video. Our approach achieves state-of-the-art results for classification, detection, tracking, and counting tasks with fewer training resource requirements than existing methods.},
    archivePrefix={arXiv},
    primaryClass={cs.CV},
    preview={saved.png},
    website={https://suzanne-stathatos.github.io/SAVeD/},
    year={2026},
    month={March}
}

@article{chen2024probingmidlevelvisioncapabilities,
      title={Probing the Mid-level Vision Capabilities of Self-Supervised Learning},
      author={Xuweiyi Chen and Markus Marks and Zezhou Cheng},
      journal={Proceedings of the IEEE/CVF Conference on Computer Vision and Pattern Recognition},
      abbr={CVPR},
      year={2025},
      eprint={2411.17474},
      archivePrefix={arXiv},
      primaryClass={cs.CV},
      arxiv={2411.17474},
      abstract={Mid-level vision capabilities are not only fundamental to human vision but also crucial for many real-world applications. Despite their significance, current self-supervised learning approaches are primarily evaluated for high-level recognition tasks. We introduce a suite of benchmark protocols to systematically assess mid-level vision capabilities and present a comprehensive evaluation of 22 prominent SSL models across 8 mid-level vision tasks. Our experiments reveal a weak correlation between mid-level and high-level task performance.},
      website={https://midvision-probe.cs.virginia.edu/},
      preview={mid_level.png},
}
@article{khalil2024sslkeypoints,
      title={Learning Keypoints for Multi-Agent Behavior Analysis using Self-Supervision},
      author={Daniel Khalil and Christina Liu and Pietro Perona and Jennifer Sun* and Markus Marks*},
      journal={(Oral) Proceedings of the IEEE/CVF Winter Conference on Applications of Computer Vision},
      abbr={WACV},
      year={2025},
      arxiv={2409.09455},
      abstract={We introduce B-KinD-multi, a novel approach that leverages pre-trained video segmentation models to guide keypoint discovery in multi-agent scenarios. This eliminates the need for time-consuming manual annotations on new experimental settings and organisms. Extensive evaluations demonstrate improved keypoint regression and downstream behavioral classification in videos of flies, mice, and rats. Our method generalizes well to other species, including ants, bees, and humans.},
      website={https://danielpkhalil.github.io/B-KinD-Multi/},
      code={https://github.com/danielpkhalil/B-KinD-Multi/tree/DEVA},
      preview={7human.gif},
}

@article{marks2024closerlookbenchmarkingselfsupervised,
      title={A Closer Look at Benchmarking Self-Supervised Pre-training with Image Classification},
      author={Markus Marks* and Manuel Knott* and Neehar Kondapaneni and Elijah Cole and Thijs Defraeye and Fernando Perez-Cruz and Pietro Perona},
      year={2025},
      arxiv={2407.12210},
      abstract={Self-supervised learning is a machine learning approach where the data itself provides supervision, eliminating the need for external labels. In Computer Vision, SSL is widely used as pre-training followed by a downstream task. However, it is not well understood how well evaluation protocols estimate the representation quality. We study how classification-based evaluation protocols for SSL correlate and how well they predict downstream performance on different dataset types. We find that in-domain linear/kNN probing protocols are, on average, the best general predictors for out-of-domain performance.},
      journal={International Journal of Computer Vision},
      abbr={Int. Journal of Computer Vision},
      url={https://arxiv.org/abs/2407.12210},
      code={https://github.com/manuelknott/ssl_eval_protocols},
      preview={ssl_metrics.png},
}

@inproceedings{kondapaneni2024less,
  title={Less is More: Discovering Concise Network Explanations},
  author={Kondapaneni, Neehar and Marks, Markus and Mac Aodha, Oisin and Perona, Pietro},
  booktitle={ICLR 2024 Workshop on Representational Alignment},
  abbr={ICLRw},
  year={2024},
  preview={dcne.png},
  url={http://arxiv.org/abs/2405.15243},
  website={https://www.vision.caltech.edu/dcne},
  arxiv={2405.15243},
  abstract={We introduce Discovering Conceptual Network Explanations (DCNE), a new approach for generating human-comprehensible visual explanations to enhance the interpretability of deep neural image classifiers. Our method automatically finds visual explanations that are critical for discriminating between classes by simultaneously optimizing three criteria: the explanations should be few, diverse, and human-interpretable. DCNE produces 1/30 of CRP's explanations while only resulting in a slight reduction in explanation quality.},
}


@article{kondapaneni2023text,
  title={Text-image Alignment for Diffusion-based Perception},
  author={Kondapaneni*, Neehar and Marks*, Markus and Knott*, Manuel and Guimar{\~a}es, Rog{\'e}rio and Perona, Pietro},
  journal={Proceedings of the IEEE/CVF Conference on Computer Vision and Pattern Recognition},
  abbr={CVPR},
  arxiv={2310.00031},
  abstract={Diffusion models are generative models with impressive text-to-image synthesis capabilities. We find that automatically generated captions can improve text-image alignment and significantly enhance a model's cross-attention maps, leading to better perceptual performance. Our approach improves upon the current state-of-the-art in diffusion-based semantic segmentation on ADE20K and the current overall SOTA for depth estimation on NYUv2. Furthermore, our method generalizes to the cross-domain setting, achieving SOTA results on Watercolor2K, Dark Zurich-val, and Nighttime Driving.},
  year={2024},
  preview={tadp.gif},
  selected={true},
  url={https://arxiv.org/abs/2310.00031},
  website={https://www.vision.caltech.edu/tadp/},
  code={https://github.com/damaggu/TADP},
}


@article{stagkourakis2023distributed,
  title={Distributed representations of innate behaviors in the hypothalamus do not predict specialized functional centers},
  author={Stagkourakis, Stefanos and Spigolon, Giada and Marks, Markus and Feyder, Michael and Kim, Joseph and Perona, Pietro and Pachitariu, Marius and Anderson, David J},
  journal={bioRxiv},
  pages={2023--11},
  year={2023},
  publisher={Cold Spring Harbor Laboratory},
  preview={vmh.png},
  html={https://www.biorxiv.org/content/10.1101/2023.11.21.568163v2.abstract},
  abstract={Artificial activation of anatomically localized, genetically defined hypothalamic neuron populations is known to trigger distinct innate behaviors. To assess whether the encoding of behavior is similarly anatomically confined, we performed simultaneous neuron recordings across twenty hypothalamic regions in freely moving animals. We show that distinct but anatomically distributed neuron ensembles encode the social and fear behavior classes, primarily through mixed selectivity.},
}



@article{ubaghs2023simultaneous,
  title={Simultaneous single-cell calcium imaging of neuronal population activity and brain-wide BOLD fMRI},
  author={Ubaghs, Rik Lodevicus Elizabeth Maria and Boehringer, Roman and Marks, Markus and Hesse, Helke Karen and Yanik, Mehmet Fatih and Zerbi, Valerio and Grewe, Benjamin Friedrich},
  journal={bioRxiv},
  pages={2023--11},
  year={2023},
  publisher={Cold Spring Harbor Laboratory},
  preview={mri_imaging.png},
  html={https://www.biorxiv.org/content/10.1101/2023.11.14.566368v1.abstract},
  note={under review at Nature Methods},
  abstract={We present a novel MRI compatible single-photon microscope capable of measuring cellular resolution calcium activity of genetically defined neurons during whole-brain BOLD fMRI in awake behaving mice. Using this combined imaging approach, we found a difference in activity patterns between cells dependent on their location with respect to the vasculature, paving the way for studies examining the interplay between local brain circuits and overarching brain functions.},
}

